":"rectangle","updated":1777724270188,"id":"idea4-box","x":80,"seed":2010,"boundElements":[],"y":637,"opacity":100,"height":113,"width":439.99999999999994,"frameId":null,"strokeStyle":"solid","versionNonce":1341653113},{"seed":2011,"strokeStyle":"solid","id":"idea4-text","strokeWidth":1,"roughness":1,"isDeleted":false,"fontSize":22,"opacity":100,"verticalAlign":"middle","updated":1777724267473,"locked":false,"text":"IDEA 4 - Event \/ Occasion Planner\nAI that plans food and groceries for\nparties or friends visiting.","version":5,"autoResize":true,"type":"text","backgroundColor":"transparent","roundness":null,"index":"b04","containerId":null,"originalText":"IDEA 4 - Event \/ Occasion Planner\nAI that plans food and groceries for\nparties or friends visiting.","height":82.5,"link":null,"strokeColor":"#111827","fillStyle":"solid","groupIds":[],"versionNonce":625286455,"textAlign":"center","fontFamily":1,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":108,"angle":0,"y":657,"width":399.49801635742188},{"isDeleted":false,"locked":false,"strokeColor":"#b45309","link":null,"roughness":1,"groupIds":[],"index":"b05","backgroundColor":"#fef3c7","angle":0,"fillStyle":"solid","strokeWidth":2,"version":114,"roundness":{"type":3},"type":"rectangle","updated":1777724224611,"id":"exploration-box","x":787,"seed":2012,"boundElements":[],"y":251,"opacity":100,"height":120,"width":340,"frameId":null,"strokeStyle":"solid","versionNonce":1631069335},{"seed":2013,"strokeStyle":"solid","id":"exploration-text","strokeWidth":1,"roughness":1,"isDeleted":false,"fontSize":24,"opacity":100,"verticalAlign":"middle","updated":1777724224611,"locked":false,"text":"Exploration\nWhat could feel ambitious,\nuseful, and demo-able?","version":149,"autoResize":true,"type":"text","backgroundColor":"transparent","roundness":null,"index":"b06","containerId":null,"originalText":"Exploration\nWhat could feel ambitious,\nuseful, and demo-able?","height":90,"link":null,"strokeColor":"#111827","fillStyle":"solid","groupIds":[],"versionNonce":974485943,"textAlign":"center","fontFamily":1,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":809,"angle":0,"y":264,"width":305.83203125},{"isDeleted":false,"locked":false,"strokeColor":"#7c3aed","link":null,"roughness":1,"groupIds":[],"index":"b07","backgroundColor":"#ede9fe","angle":0,"fillStyle":"solid","strokeWidth":2,"version":177,"roundness":{"type":3},"type":"rectangle","updated":1777724224611,"id":"tradeoff-box","x":767,"seed":2014,"boundElements":[],"y":414,"opacity":100,"height":322.00000000000006,"width":587.99999999999989,"frameId":null,"strokeStyle":"solid","versionNonce":1925917399},{"seed":2015,"strokeStyle":"solid","id":"tradeoff-text","strokeWidth":1,"roughness":1,"isDeleted":false,"fontSize":22,"opacity":100,"verticalAlign":"top","updated":1777724224611,"locked":false,"text":"Tradeoffs\n- Smart day planner felt too broad for one POC.\n- Group ordering needed multi-user coordination.\n- Health-first agent needed deeper nutrition data.\n- Event planner was compelling, but episodic.\n\nSo we narrowed to a more grounded,\nrepeatable daily\/weekly planning experience.","version":115,"autoResize":true,"type":"text","backgroundColor":"transparent","roundness":null,"index":"b08","containerId":null,"originalText":"Tradeoffs\n- Smart day planner felt too broad for one POC.\n- Group ordering needed multi-user coordination.\n- Health-first agent needed deeper nutrition data.\n- Event planner was compelling, but episodic.\n\nSo we narrowed to a more grounded,\nrepeatable daily\/weekly planning experience.","height":220,"link":null,"strokeColor":"#111827","fillStyle":"solid","groupIds":[],"versionNonce":669890551,"textAlign":"left","fontFamily":1,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":800,"angle":0,"y":476,"width":540.56201171875},{"isDeleted":false,"locked":false,"strokeColor":"#15803d","link":null,"roughness":1,"groupIds":[],"index":"b09","backgroundColor":"#dcfce7","angle":0,"fillStyle":"solid","s